# ============================================================================
# Docker build context exclusions for Dockerfile.unified
#
# Keeps the build context small by excluding:
#   - Python virtual environments and caches
#   - Node modules (reinstalled in build stage)
#   - Git history and IDE configs
#   - Development-only files
#   - Infrastructure and provisioning scripts (not needed at runtime)
# ============================================================================

# Python
**/__pycache__/
**/.venv/
**/*.pyc
**/*.pyo

# Node
**/node_modules/
**/dist/

# Git & IDE
.git/
.gitignore
**/.vscode/
**/.idea/

# Development artifacts
**/README.md
**/DESIGN.md
**/DEV.md
**/API_CONTRACT.md
AGENT_SKILLS/

# Infrastructure and provisioning (not needed in the app container)
graph_data/infra/
graph_data/hooks/
graph_data/.azure/
graph_data/deploy.sh
graph_data/azure.yaml
graph_data/azure_config.env
graph_data/azure_config.env.template
graph_data/README.md

# Scenario data exclusions: CSVs and knowledge/ live in Azure (Fabric + AI Search)
# These are NOT needed in the app container — only prompts, schema, topology, config.
**/*.csv
graph_data/data/scenarios/*/data/knowledge/
graph_data/data/scenarios/*/data/entities/
graph_data/data/scenarios/*/data/telemetry/

# Deploy scripts (not needed inside the container)
control/deploy_app.sh
control/deploy_infra.sh

# Docker files
Dockerfile.unified
app/dev.sh

# Test and dev files
**/tests/
control/.env
control/.env.template
