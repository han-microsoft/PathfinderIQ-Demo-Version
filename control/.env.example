# ══════════════════════════════════════════════════════════════════
# control/.env.example — Environment Configuration Template
# ══════════════════════════════════════════════════════════════════
#
# Copy this file to control/.env and fill in your values:
#   cp control/.env.example control/.env
#
# control/.env is git-ignored. Never commit secrets.
#
# Auth model:
#   Fabric:  ClientSecretCredential (cross-tenant SP) or AzureCliCredential
#   All other services: DefaultAzureCredential (az login locally, managed
#   identity deployed). No API keys.
#
# Per-scenario resource IDs (workspace, graph model, eventhouse, search
# indexes) live in each scenario's scenario.yaml — NOT here.
#
# See CONFIGURATION.md for the full config location guide.
# ══════════════════════════════════════════════════════════════════

# ── REQUIRED: Azure AI Agent Framework ───────────────────────────
# Get from: AI Foundry → Project → Overview
AZURE_AI_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=gpt-5.2

# ── REQUIRED: Scenario Selection ─────────────────────────────────
# Which scenario folder under graph_data/data/scenarios/ to load.
# Everything else (agents, tools, prompts, Fabric IDs) comes from
# the scenario's scenario.yaml file.
SCENARIO_NAME=telecom-playground-v2
LLM_PROVIDER=agent

# ── REQUIRED: Azure AI Search ────────────────────────────────────
# Enables document search tools (runbooks, tickets, equipment, specs).
# Auth: DefaultAzureCredential (az login locally, managed identity deployed).
AI_SEARCH_ENDPOINT=https://your-search.search.windows.net

# ── OPTIONAL: Fabric credentials (cross-tenant SP) ───────────────
# Set all three to use ClientSecretCredential for cross-tenant Fabric access.
# Leave empty/unset to use AzureCliCredential (same-tenant, your az login).
# For production: FABRIC_CLIENT_SECRET comes from Key Vault (not here).
FABRIC_TENANT_ID=
FABRIC_CLIENT_ID=
FABRIC_CLIENT_SECRET=    # LOCAL DEV ONLY — production uses Key Vault

# ── OPTIONAL: Authentication ─────────────────────────────────────
# Default: auth_enabled=true in config.py but requires AUTH_CLIENT_ID.
# Set AUTH_ENABLED=false for local dev without Entra login.
# See CONFIGURATION.md for app registration steps.
AUTH_ENABLED=false
# AUTH_CLIENT_ID=        # REQUIRED when AUTH_ENABLED=true
# AUTH_TENANT_ID=common  # "common" for multi-tenant (default)

# ── OPTIONAL: Session Persistence ────────────────────────────────
# Empty = in-memory (data lost on restart, fine for dev).
# Set to Cosmos DB endpoint for durable sessions.
# COSMOS_SESSION_ENDPOINT=https://your-cosmos.documents.azure.com:443/

# ── OPTIONAL: Observability ──────────────────────────────────────
# "" = noop (default in config.py is "console"). "azure" = App Insights.
# OTEL_EXPORT_TARGET=
# APPLICATIONINSIGHTS_CONNECTION_STRING=
