# ============================================================================
# Graph Data Provisioner — Configuration Template
# ============================================================================
# This file is the SINGLE source of truth for the config file structure.
# deploy.sh copies it to azure_config.env and fills values via set_config().
# Do NOT edit azure_config.env directly — it is regenerated every deploy.
# ============================================================================

# --- Scenario ---
# DEFAULT_SCENARIO is no longer used by deploy_infra.sh.
# Scenario deployment is handled separately by per-scenario scripts.

# --- Core Azure settings (AUTO: populated by postprovision) ---
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_LOCATION=swedencentral

# --- AI Foundry (AUTO: populated by postprovision) ---
AI_FOUNDRY_NAME=
AI_FOUNDRY_ENDPOINT=
AI_FOUNDRY_PROJECT_NAME=
PROJECT_ENDPOINT=

# --- Model deployments (USER: must match infra/modules/ai-foundry.bicep) ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
CHAT_MODEL_DEPLOYMENT=gpt-5.2
GPT_CAPACITY_1K_TPM=300

# --- Azure AI Search (AUTO: populated by postprovision) ---
AI_SEARCH_NAME=

# --- Azure Storage (AUTO: populated by postprovision) ---
STORAGE_ACCOUNT_NAME=
STORAGE_PACKAGE_CONTAINER=scenario-packages
PACKAGE_BLOB_ROOT=landing/scenarios
STORAGE_REPORTS_CONTAINER=publish-reports
PUBLISH_REPORT_BLOB_ROOT=reports/publishes

# --- Container App Infrastructure (AUTO: populated by deploy.sh --app-infra) ---
CONTAINER_APPS_ENV_NAME=
ACR_NAME=
ACR_LOGIN_SERVER=
APP_URL=
APP_IDENTITY_ID=
APP_IDENTITY_CLIENT_ID=
PUBLISH_JOB_NAME=
KEY_VAULT_NAME=
KEY_VAULT_URI=

# --- Fabric Cross-Tenant Service Principal (USER for cross-tenant deployments) ---
# Only required when Fabric workspace lives in a different Entra ID tenant.
# Leave empty for same-tenant deployments (DefaultAzureCredential used).
FABRIC_TENANT_ID=
FABRIC_CLIENT_ID=
FABRIC_CLIENT_SECRET=
